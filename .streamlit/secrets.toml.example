# Streamlit Cloud 배포 시 사용할 Secrets 템플릿
# ─────────────────────────────────────────────
# 실제 배포 시에는 이 파일을 복사해서 `.streamlit/secrets.toml`로 만들고
# 아래 값들을 실제 값으로 채워주세요.
# ⚠ secrets.toml은 절대 GitHub에 커밋하지 마세요! (.gitignore에 이미 제외됨)
#
# Streamlit Cloud에서는:
#   1. streamlit.io → 앱 대시보드 → ⚙ Settings → Secrets
#   2. 아래 내용 전체를 붙여넣기
#   3. Save

[firebase]
# Firebase Admin SDK 서비스 계정 JSON 내용을 그대로 붙여넣기
# (dashboard-XXXX-firebase-adminsdk-XXXX.json 파일 내용)
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxx"
private_key = """-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQ...
...여러 줄에 걸친 private key 전체 내용...
...
-----END PRIVATE KEY-----
"""
client_email = "firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
